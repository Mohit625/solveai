PORT=4000
NODE_ENV=development
LOG_LEVEL=info
# Comma-separated list of allowed browser origins, or "*" for any.
# Local dev / Docker: http://localhost,http://localhost:5173
# Vercel: the deployed client project's URL, e.g. https://solveai-client.vercel.app
ALLOWED_ORIGIN=http://localhost,http://localhost:5173
REQUEST_TIMEOUT_MS=90000

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local dev / Docker: redis://redis:6379 (or redis://localhost:6379 outside Docker)
# Vercel: an external managed Redis connection string, e.g. Upstash's
#   rediss://default:<password>@<endpoint>.upstash.io:6379
# (Vercel has no persistent compute/storage — a self-hosted Redis container
# isn't an option there.)
REDIS_URL=redis://redis:6379

# kimi | gemini
AI_PROVIDER=kimi

KIMI_API_BASE_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.7-code

# From https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# Screenshot text extraction — mistral-ocr-latest is a dedicated OCR model,
# not a chat/reasoning model, so it won't "solve"/summarize instead of
# transcribe.
VISION_PROVIDER=mistral
MISTRAL_API_KEY=

RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_SECONDS=60

CACHE_TTL_SECONDS=2592000
